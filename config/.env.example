# Moomoo OpenD 连接（在本地运行 OpenD 后无需其他密钥）
# 下载地址：https://www.moomoo.com/download/openD
MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=11111

# Telegram Bot（从 @BotFather 获取）
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 数据库路径
DB_PATH=./data/signals.db

# 影子模式（可选）：免费的Gemini模型跑一份独立判断，只记录对比，不下单
# 不配置则自动跳过整个影子流程，不影响主流程
# 获取地址：https://aistudio.google.com/apikey
GEMINI_API_KEY=
